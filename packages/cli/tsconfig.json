{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "composite": true,
    "jsx": "react"
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../../shared" },
    { "path": "../gateway" },
    { "path": "../agents" },
    { "path": "../canvas" },
    { "path": "../dashboard" },
    { "path": "../channels" },
    { "path": "../voice" }
  ]
}
