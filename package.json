{
  "name": "@kushuri12/ohiru",
  "version": "1.6.2",
  "description": "OpenHiru — AI agent controlled via Telegram",
  "bin": {
    "ohiru": "./packages/cli/dist/index.js",
    "openhiru": "./packages/cli/dist/index.js"
  },
  "type": "module",
  "files": [
    "packages/cli/dist",
    "packages/gateway/dist",
    "packages/dashboard/dist",
    "packages/canvas/dist",
    "packages/agents/dist",
    "packages/channels/dist",
    "packages/voice/dist",
    "packages/skills/dist",
    "shared/dist",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json && node scripts/copy-ui.js",
    "dev": "tsx packages/cli/src/index.ts",
    "start": "node packages/cli/dist/index.js"
  },
  "workspaces": [
    "packages/*",
    "shared"
  ],
  "dependencies": {
    "@ai-sdk/anthropic": "latest",
    "@ai-sdk/cohere": "latest",
    "@ai-sdk/google": "latest",
    "@ai-sdk/groq": "latest",
    "@ai-sdk/mistral": "latest",
    "@ai-sdk/openai": "latest",
    "ai": "latest",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.16",
    "node-fetch": "latest",
    "node-html-markdown": "^2.0.0",
    "ora": "latest",
    "shared": "*",
    "uuid": "latest",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.24",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.7.1",
    "typescript": "^6.0.3",
    "vitest": "^1.3.1"
  }
}
