    "axios": "^1.15.2",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "grammy": "latest",
    "ink": "^7.0.1",
    "inquirer": "^13.4.2",
